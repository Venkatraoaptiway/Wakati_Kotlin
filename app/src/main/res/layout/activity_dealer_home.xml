<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_color"
    android:fillViewport="true"
    android:fitsSystemWindows="false"
    tools:context=".dealer.DealerHomeActivity">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Top bar -->
        <RelativeLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_120sdp"
            android:background="@drawable/top_bar"
            android:paddingLeft="@dimen/_5sdp"
            android:paddingTop="@dimen/_10sdp">

            <LinearLayout
                android:id="@+id/profile_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">


                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profile_image"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_below="@+id/back_layout"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="10dp"
                    android:src="@color/white" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/_15sdp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/welcome_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:layout_toEndOf="@id/profile_image"
                        android:text="@string/welcome"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />


                    <TextView
                        android:id="@+id/user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/welcome_text"
                        android:layout_alignStart="@id/welcome_text"
                        android:text="@string/zanele_okonkwo"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/montserrat_bold" />
                </LinearLayout>
            </LinearLayout>


            <!-- Language and notification icon -->
            <ImageView
                android:id="@+id/notification_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_26sdp"
                android:layout_marginEnd="@dimen/_40sdp"
                android:src="@drawable/baseline_circle_notifications_24" />

            <!-- Language and notification icon -->
            <ImageView
                android:id="@+id/logout_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_26sdp"
                android:layout_marginEnd="@dimen/_12sdp"
                android:src="@drawable/outline_arrow_circle_right_24" />
        </RelativeLayout>


        <RelativeLayout
            android:id="@+id/account_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/top_bar"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_minus40sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:background="@drawable/home_card_bg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_10sdp">


                <LinearLayout
                    android:id="@+id/layout_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="@string/wallet_balance"
                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/wallet_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"
                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_14ssp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="@string/available_balance"
                            android:textColor="@color/blue_color"

                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/available_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"

                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_14ssp" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:background="@drawable/homecardlogo"
                        android:gravity="end" />


                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout_1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"

                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="@string/deposit"

                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/deposits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"

                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_14ssp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="@string/withdraw"

                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/withdrawals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"

                            android:textColor="@color/blue_color"
                            android:textSize="@dimen/_14ssp" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableRight="@drawable/lock"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="@string/security_deposit"
                            android:textColor="@color/light_red_color"
                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/security_deposites"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"

                            android:textColor="@color/light_red_color"
                            android:textSize="@dimen/_14ssp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="@string/earned_commission"

                            android:textColor="@color/light_red_color"
                            android:textSize="@dimen/_11ssp" />

                        <TextView
                            android:id="@+id/earned_commission"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingTop="@dimen/_5sdp"
                            android:text="O KMF"

                            android:textColor="@color/light_red_color"
                            android:textSize="@dimen/_14ssp" />


                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>


        <TextView
            android:id="@+id/services_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/account_card"
            android:layout_marginStart="16dp"
            android:layout_marginTop="@dimen/_5sdp"
            android:fontFamily="@font/montserrat_bold"
            android:text="@string/services"
            android:textColor="@color/black"
            android:textSize="@dimen/_15ssp" />


        <LinearLayout
            android:id="@+id/services_icons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/services_label"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_6sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_6sdp"
            android:orientation="horizontal"
            android:weightSum="4">


            <!-- Repeat for each service icon -->
            <LinearLayout
                android:id="@+id/transfer_fragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/deposit_money"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/deposite" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:text="@string/deposit_money"
                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/top_up_fragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/withdrawal_money"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/withdraw" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:text="@string/withdraw_money"
                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pay_bills_fragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/transactions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/transactions" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:text="@string/transaction"

                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/my_account_fragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/my_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/profile" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:text="@string/my_profile"

                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>

        </LinearLayout>



        <TextView
            android:id="@+id/tvRecentTransactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/services_icons"
            android:layout_marginStart="16dp"
            android:layout_marginTop="@dimen/_6sdp"
            android:text="@string/transactions"
            android:textColor="@color/black"
            android:textSize="@dimen/_15ssp"
            android:fontFamily="@font/montserrat_bold" />


        <!-- SEARCH BAR -->
        <LinearLayout
            android:id="@+id/searchLayout"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_below="@+id/tvRecentTransactions"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/search_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- SEARCH ICON -->
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/search_icon"
                app:tint="#7A7A7A" />

            <!-- EDIT TEXT -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="@font/montserrat_regular"
                android:hint="Search by name or number"
                android:inputType="text"
                android:textColor="#000000"
                android:textColorHint="#8A8A8A"
                 />

            <!-- FILTER ICON -->
            <ImageView
                android:id="@+id/imgFilter"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/filters"
                app:tint="#1E88E5" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/searchLayout"
            >



        <LinearLayout
            android:id="@+id/transactionsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Transaction 1 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransferHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />


        </LinearLayout>

        </ScrollView>

    </RelativeLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


</RelativeLayout>