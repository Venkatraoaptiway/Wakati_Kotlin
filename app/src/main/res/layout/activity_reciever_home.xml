                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="@string/total_frontdesk"
                                    android:textColor="@color/blue_color"
                                    android:textSize="@dimen/_11ssp" />

                                <TextView
                                    android:id="@+id/frontdeskTotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:text="0"
                                    android:textColor="@color/blue_gray_text_color"
                                    android:textSize="@dimen/_11ssp" />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingLeft="@dimen/_10sdp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/active"
                                    android:textColor="@color/red_color" />

                                <TextView
                                    android:id="@+id/frontdeskActive"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:text="0"
                                    android:textColor="@color/red_color"
                                    android:textSize="@dimen/_11ssp" />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingLeft="@dimen/_10sdp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="@string/blocked"
                                    android:textColor="@color/red_color"
                                    android:textSize="@dimen/_11ssp" />

                                <TextView
                                    android:id="@+id/frontdeskInactive"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="0"
                                    android:textColor="@color/red_color"
                                    android:textSize="@dimen/_11ssp" />


                            </LinearLayout>


                        </LinearLayout>


                    </LinearLayout>

                    <TextView
                        android:id="@+id/assign_dealers_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_45sdp"
                        android:layout_marginRight="@dimen/_45sdp"
                        android:background="@drawable/button_bg"
                        android:layout_below="@id/total_frontdesk_layout"
                        android:fontFamily="@font/montserrat_medium"
                        android:gravity="center"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:padding="@dimen/_13sdp"
                        android:text="@string/assign_dealers"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_14ssp" />


                    <LinearLayout
                        android:id="@+id/tvRecentTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/assign_dealers_btn"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="@dimen/_6sdp"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="@string/transactions"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_15ssp" />

                        <TextView
                            android:id="@+id/transactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_6sdp"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="end"
                            android:singleLine="true"
                            android:text="@string/view_transactions"
                            android:layout_marginRight="@dimen/_5sdp"
                            android:textColor="@color/red_color"
                            android:textSize="@dimen/_11ssp" />
                        />

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/transactionsLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp">

                        <!-- Transaction 1 -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvTransferHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" />


                    </LinearLayout>


                </LinearLayout>





        </RelativeLayout>
    </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


</RelativeLayout>