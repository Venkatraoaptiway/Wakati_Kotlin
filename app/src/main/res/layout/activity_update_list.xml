<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".agent.UpdateListActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TOP BAR -->

        <LinearLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_26sdp"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/backArrow"
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:src="@drawable/baseline_arrow_back_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Deposit Money"
                android:textColor="@color/red_color"
                android:textSize="@dimen/_17ssp" />

            <ImageView
                android:layout_width="@dimen/_35sdp"
                android:layout_height="@dimen/_35sdp"
                android:src="@drawable/hurilogo" />

        </LinearLayout>




        <TextView
            android:id="@+id/text1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/topLayout"
            android:fontFamily="@font/montserrat_medium"
            android:text="@string/list_of_accounts"
            android:layout_margin="@dimen/_8sdp"
            android:textColor="@color/light_red_color"
            android:textSize="@dimen/_17ssp" />


    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_marginEnd="16dp"
        android:layout_below="@+id/text1"
        android:background="@drawable/edittext_bg1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">



        <!-- EDIT TEXT -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:hint="Search by name or number"
            android:inputType="text"
            android:textColor="#000000"
            android:textColorHint="#8A8A8A"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium" />



    </LinearLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fetchaccounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/searchLayout"
            android:layout_margin="@dimen/_8sdp"
            />


    </RelativeLayout>


</ScrollView>