<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:background="@color/white_color"
    android:paddingBottom="4dp">

    <!-- TOP ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- LEFT ICON -->
        <ImageView
            android:id="@+id/imgTransaction"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/baseline_call_made_24" />

        <!-- CENTER DETAILS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Received from"
                android:textColor="#888888"
                android:textSize="@dimen/_9ssp"
                android:fontFamily="@font/montserrat_medium" />

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Super Dealer"
                android:textColor="#4A4A4A"
                android:textSize="@dimen/_10ssp"
                android:fontFamily="@font/montserrat_medium" />

            <TextView
                android:id="@+id/txtPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="+2693422222"
                android:textColor="#666666"
                android:textSize="@dimen/_10ssp"
                android:fontFamily="@font/montserrat_bold" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PAY CASH on 2026-05-21 14:48:01"
                android:textColor="#999999"
                android:textSize="12sp"
                android:fontFamily="@font/montserrat_medium" />

        </LinearLayout>

        <!-- RIGHT AMOUNT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 50 000 KMF"
                android:textColor="#3BAA5C"
                android:textSize="@dimen/_11ssp"
                android:fontFamily="@font/montserrat_regular" />

            <TextView
                android:id="@+id/txtCommission"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="comm: 1 250 KMF"
                android:textColor="#8B0000"
                android:textSize="14sp"
                android:visibility="gone"
                android:fontFamily="@font/montserrat_medium" />

        </LinearLayout>

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#E5E5E5" />

</LinearLayout>