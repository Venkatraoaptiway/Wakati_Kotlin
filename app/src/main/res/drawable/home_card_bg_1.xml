<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background Color -->
    <solid android:color="@color/card_bg" />

    <!-- Corner Radius -->
    <corners android:radius="20dp" />

    <!-- Optional Border -->
    <stroke
        android:width="0.7dp"
        android:color="#888787" />

    <!-- Optional Padding -->
    <padding
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp" />

</shape>