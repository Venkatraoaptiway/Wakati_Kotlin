<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@android:color/white" />

    <!-- Border line -->
    <stroke
        android:width="1dp"
        android:color="#BDBDBD" /> <!-- Light grey border -->

    <!-- Rounded corners -->
    <corners android:radius="@dimen/_13sdp" />

    <!-- Optional padding inside EditText -->
    <padding
        android:left="8dp"
        android:top="4dp"
        android:right="8dp"
        android:bottom="4dp" />
</shape>
